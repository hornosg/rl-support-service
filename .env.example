# support-service — copiá a .env y completá los valores. NUNCA commitees .env (lleva secretos).

# Superusuario de PostgreSQL (lo usa solo el provisioning / control-plane)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Password del rol de aplicación (app-plane, sin DDL)
APP_DB_PASSWORD=

# Secreto para validar los JWT del servicio de identidad
JWT_SECRET=

# Tenancy: true = multi-tenant con RLS (default). false = single-tenant.
MULTITENANT=true
